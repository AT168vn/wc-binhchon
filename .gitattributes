# --------------------------------------------
# 🌐 Normalize text files to LF for consistency
# --------------------------------------------

# Set the default behavior to automatically normalize line endings
* text=auto

# Force LF for common code files
*.js     text eol=lf
*.jsx    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.css    text eol=lf
*.scss   text eol=lf
*.html   text eol=lf
*.md     text eol=lf
*.sh     text eol=lf
*.env    text eol=lf

# Windows-only files (optional, for .bat scripts)
*.bat    text eol=crlf

# Binary files - don't modify
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.exe    binary
*.dll    binary
