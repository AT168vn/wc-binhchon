# =============================================================================
# WC Bình chọn — biến môi trường mẫu
# Copy thành .env.local để chạy local, hoặc nhập vào Vercel → Settings → Environment Variables
# KHÔNG commit file .env chứa mật khẩu thật lên GitHub
# =============================================================================

# --- PostgreSQL (bắt buộc) — chọn MỘT trong hai cách ---

# Cách 1 (khuyến nghị trên Vercel / Neon / Supabase): connection string đầy đủ
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Cách 2: từng biến riêng (VPS / IIS)
VIMES_DB_HOST=118.70.52.87
VIMES_DB_PORT=5432
VIMES_DB_USER=postgres
VIMES_DB_PASSWORD=nguginoi
VIMES_DB_NAME=vimes_jsc_new
# Bật SSL khi DB cloud (Vercel → PostgreSQL ngoài): true
VIMES_DB_SSL=false

# --- Bảo mật session & cookie (bắt buộc trên production) ---
# Chuỗi ngẫu nhiên ≥ 32 ký tự — dùng ký JWT đăng nhập WC
WC_SESSION_SECRET=change-me-to-a-long-random-secret-string

# Khóa mã hóa token trong cookie trình duyệt (AES)
NEXT_PUBLIC_API_KEY=change-me-to-another-random-key

# --- Giao diện (tùy chọn) ---
NEXT_PUBLIC_TEN_HIEN_THI=World Cup 2026
NEXT_PUBLIC_TEN_VERSION=WC Bình chọn
NEXT_PUBLIC_VERSION=1.0.0
NEXT_PUBLIC_TIMEOUT=30

# --- Chỉ dùng khi deploy GitHub Pages (frontend tách API) ---
# NEXT_PUBLIC_BASE_PATH=/wc-binhchon
# NEXT_PUBLIC_APP_API_BASE=https://wc-binhchon.vercel.app
